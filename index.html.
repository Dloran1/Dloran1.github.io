// screens/LeagueScreen.js
import React, { useEffect, useMemo, useRef, useState } from "react";
import { View, Text, FlatList, TouchableOpacity, ScrollView, TextInput, Pressable } from "react-native";
import { THEME } from "../theme";
import { API_BASE, API_KEY } from "../config";
import { finishedCodes, liveCodes, fmtDT, safeNum, clamp01 } from "../helpers";
import { CenterLoading, Card } from "../Common";

function Tab({ id, cur, title, onPress }) {
  const active = cur === id;
  return (
    <TouchableOpacity
      onPress={() => onPress(id)}
      style={{
        paddingVertical: 10,
        paddingHorizontal: 14,
        backgroundColor: active ? THEME.accent : THEME.card,
        borderWidth: 1,
        borderColor: active ? THEME.accent : THEME.border,
        borderRadius: 10,
        marginRight: 8,
      }}
    >
      <Text style={{ color: active ? "#001a13" : THEME.text, fontWeight: "800" }}>
        {title}
      </Text>
    </TouchableOpacity>
  );
}

function Chip({ title, active, onPress }) {
  return (
    <Pressable
      onPress={onPress}
      android_ripple={{ color: "#00000022" }}
      style={({ pressed }) => ({
        paddingVertical: 8, paddingHorizontal: 12,
        backgroundColor: active ? THEME.accent2 : (pressed ? THEME.accent + "22" : THEME.card),
        borderWidth: 1, borderColor: active ? THEME.accent2 : THEME.border,
        borderRadius: 10, marginRight: 8, marginTop: 8,
      })}
    >
      <Text style={{ color: active ? "#00131A" : THEME.text, fontWeight: "700" }}>{title}</Text>
    </Pressable>
  );
}

export default function LeagueScreen({ route, navigation }) {
  const { league } = route.params;
  const season = league.season || new Date().getFullYear();

  const [tab, setTab] = useState("schedule"); // schedule | table | ratings | refs
  const [flt, setFlt] = useState("live"); // live | next | played
  const [loading, setLoading] = useState(true);

  const [fixtures, setFixtures] = useState([]);
  const [standings, setStandings] = useState([]);

  // агрегаты
  const [cornersStats, setCornersStats] = useState(null); // team -> {avg, over10_5, under10_5, played}
  const [cardsStats, setCardsStats] = useState(null);     // team -> {avg, over5_5, under5_5, played}
  const [goalsIndex, setGoalsIndex] = useState(null);     // team -> {pOver25,pOver35,played}
  const [lateStats, setLateStats] = useState(null);       // team -> {pScoreLate,played}
  const [refStats, setRefStats] = useState(null);         // ref -> {avgYellows,avgFouls,pOver,played}

  const statsCache = useRef(new Map());   // fixtureId -> statistics[]
  const eventsCache = useRef(new Map());  // fixtureId -> events[]

  // ----- Загрузка -----
  useEffect(() => {
    let alive = true;
    (async () => {
      setLoading(true);
      try {
        // все матчи лиги в сезоне
        const fx = await fetch(
          `${API_BASE}/fixtures?league=${league.id}&season=${season}`,
          { headers: { "x-apisports-key": API_KEY } }
        ).then((r) => r.json());
        const rows = (fx?.response || []).map((f) => ({
          id: f.fixture?.id,
          date: f.fixture?.date,
          status: f.fixture?.status?.short,
          time: f.fixture?.status?.elapsed ?? 0,
          home: f.teams?.home?.name,
          away: f.teams?.away?.name,
          homeId: f.teams?.home?.id,
          awayId: f.teams?.away?.id,
          gH: f.goals?.home,
          gA: f.goals?.away,
          referee: f.fixture?.referee || null,
        }));

        // таблица
        let table = [];
        try {
          const st = await fetch(
            `${API_BASE}/standings?league=${league.id}&season=${season}`,
            { headers: { "x-apisports-key": API_KEY } }
          ).then((r) => r.json());
          const block = st?.response?.[0]?.league?.standings?.[0] || [];
          table = block.map((row) => ({
            rank: row?.rank,
            team: row?.team?.name,
            teamId: row?.team?.id,
            played: row?.all?.played,
            win: row?.all?.win,
            draw: row?.all?.draw,
            lose: row?.all?.lose,
            gf: row?.all?.goals?.for,
            ga: row?.all?.goals?.against,
            gd: (row?.all?.goals?.for ?? 0) - (row?.all?.goals?.against ?? 0),
            pts: row?.points,
            form: row?.form || "",
          }));
        } catch (e) {
          console.log("standings err", e);
        }

        if (!alive) return;
        setFixtures(rows);
        setStandings(table);

        // агрегаты по ~120 последним завершенным матчам
        const finished = rows.filter((m) => finishedCodes.has(m.status));
        const sample = finished
          .sort((a, b) => new Date(b.date) - new Date(a.date))
          .slice(0, 120);

        const fetchStat = async (fid) => {
          if (statsCache.current.has(fid)) return statsCache.current.get(fid);
          const j = await fetch(`${API_BASE}/fixtures/statistics?fixture=${fid}`, {
            headers: { "x-apisports-key": API_KEY },
          })
            .then((r) => r.json())
            .catch(() => ({}));
          const val = j?.response || [];
          statsCache.current.set(fid, val);
          return val;
        };
        const fetchEv = async (fid) => {
          if (eventsCache.current.has(fid)) return eventsCache.current.get(fid);
          const j = await fetch(`${API_BASE}/fixtures/events?fixture=${fid}`, {
            headers: { "x-apisports-key": API_KEY },
          })
            .then((r) => r.json())
            .catch(() => ({}));
          const val = j?.response || [];
          eventsCache.current.set(fid, val);
          return val;
        };
        const chunk = (arr, n) => {
          const out = [];
          for (let i = 0; i < arr.length; i += n) out.push(arr.slice(i, i + n));
          return out;
        };

        const cMap = new Map(); // team -> {sum, played, over, under}
        const yMap = new Map(); // team -> {sum, played, over, under}
        const gMap = new Map(); // team -> {played, over25, over35}
        const lMap = new Map(); // team -> {played, lateScored}
        const rMap = new Map(); // ref -> {played,sumY,sumF,over}

        const ensure = (mp, k, init) => {
          if (!mp.has(k)) mp.set(k, { ...init });
          return mp.get(k);
        };

        for (const group of chunk(sample, 10)) {
          const all = await Promise.all(group.map((g) => fetchStat(g.id)));
          for (let i = 0; i < group.length; i++) {
            const game = group[i];
            const stats = all[i] || [];
            let cornersTotal = 0;
            let cardsTotal = 0;
            let foulsTotal = 0;

            for (const side of stats) {
              const tname = side?.team?.name;
              const list = side?.statistics || [];
              const corners = safeNum(list.find((s) => s?.type === "Corner Kicks")?.value);
              const cards = safeNum(list.find((s) => s?.type === "Yellow Cards")?.value);
              const fouls = safeNum(list.find((s) => s?.type === "Fouls")?.value);
              cornersTotal += corners;
              cardsTotal += cards;
              foulsTotal += fouls;

              const c = ensure(cMap, tname, { sum: 0, played: 0, over: 0, under: 0 });
              c.sum += corners;
              c.played += 1;

              const y = ensure(yMap, tname, { sum: 0, played: 0, over: 0, under: 0 });
              y.sum += cards;
              y.played += 1;
            }

            const totalGoals = safeNum(game.gH) + safeNum(game.gA);
            const gh = ensure(gMap, game.home, { played: 0, over25: 0, over35: 0 });
            const ga = ensure(gMap, game.away, { played: 0, over25: 0, over35: 0 });
            gh.played++; ga.played++;
            if (totalGoals > 2.5) { gh.over25++; ga.over25++; }
            if (totalGoals > 3.5) { gh.over35++; ga.over35++; }

            if (cornersTotal > 10.5) { cMap.get(game.home).over++; cMap.get(game.away).over++; }
            else { cMap.get(game.home).under++; cMap.get(game.away).under++; }
            if (cardsTotal > 5.5) { yMap.get(game.home).over++; yMap.get(game.away).over++; }
            else { yMap.get(game.home).under++; yMap.get(game.away).under++; }

            const ref = game.referee || "Unknown referee";
            const rr = ensure(rMap, ref, { played: 0, sumY: 0, sumF: 0, over: 0 });
            rr.played++;
            rr.sumY += cardsTotal;
            rr.sumF += foulsTotal;
            if (cardsTotal > 5.5) rr.over++;
          }
        }

        // поздние голы
        for (const group of chunk(sample, 12)) {
          const allE = await Promise.all(group.map((g) => fetchEv(g.id)));
          for (let i = 0; i < group.length; i++) {
            const game = group[i];
            const events = allE[i] || [];
            const h = ensure(lMap, game.home, { played: 0, lateScored: 0 });
            const a = ensure(lMap, game.away, { played: 0, lateScored: 0 });
            h.played++; a.played++;
            for (const e of events) {
              if (e?.type !== "Goal") continue;
              const t = safeNum(e?.time?.elapsed);
              if (t >= 75) {
                if (e?.team?.name === game.home) h.lateScored++;
                if (e?.team?.name === game.away) a.lateScored++;
              }
            }
          }
        }

        // финальные объекты
        const cOut = {};
        cMap.forEach((v, k) => {
          const avg = v.played ? v.sum / v.played : 0;
          cOut[k] = {
            avg: +avg.toFixed(2),
            over10_5: v.over,
            under10_5: v.under,
            played: v.played,
          };
        });
        const yOut = {};
        yMap.forEach((v, k) => {
          const avg = v.played ? v.sum / v.played : 0;
          yOut[k] = {
            avg: +avg.toFixed(2),
            over5_5: v.over,
            under5_5: v.under,
            played: v.played,
          };
        });
        const gOut = {};
        gMap.forEach((v, k) => {
          const p = v.played || 1;
          gOut[k] = {
            played: v.played,
            pOver25: Math.round((v.over25 / p) * 100),
            pOver35: Math.round((v.over35 / p) * 100),
          };
        });
        const lOut = {};
        lMap.forEach((v, k) => {
          const p = v.played || 1;
          lOut[k] = { pScoreLate: Math.round((v.lateScored / p) * 100), played: v.played };
        });
        const rOut = {};
        rMap.forEach((v, k) => {
          const p = v.played || 1;
          rOut[k] = {
            avgYellows: +(v.sumY / p).toFixed(2),
            avgFouls: +(v.sumF / p).toFixed(2),
            pOver: Math.round((v.over / p) * 100),
            played: v.played,
          };
        });

        if (!alive) return;
        setCornersStats(cOut);
        setCardsStats(yOut);
        setGoalsIndex(gOut);
        setLateStats(lOut);
        setRefStats(rOut);
      } catch (e) {
        console.log("league root err", e);
      } finally {
        if (alive) setLoading(false);
      }
    })();
    return () => { alive = false; };
  }, [league.id, season]);

  // ---- фильтрация расписания ----
  const filteredFixtures = useMemo(() => {
    if (!fixtures.length) return [];
    const now = Date.now();
    if (flt === "live") return fixtures.filter((m) => liveCodes.has(m.status));
    if (flt === "next") {
      const upcoming = fixtures.filter((m) => {
        const dt = new Date(m.date).getTime();
        const isUpcoming = m.status === "NS" || dt > now;
        return !liveCodes.has(m.status) && !finishedCodes.has(m.status) && isUpcoming;
      });
      return upcoming.sort((a, b) => new Date(a.date) - new Date(b.date)).slice(0, 60);
    }
    return fixtures
      .filter((m) => finishedCodes.has(m.status))
      .sort((a, b) => new Date(b.date) - new Date(a.date))
      .slice(0, 60);
  }, [fixtures, flt]);

  const openMatch = (m) => {
    navigation.navigate("Match", {
      fixtureId: String(m.id),
      homeId: m.homeId,
      awayId: m.awayId,
      homeName: m.home,
      awayName: m.away,
      goalsIndex,
      cornersStats,
      cardsStats,
      lateStats,
      refStats,
      refereeName: m.referee || null,
    });
  };

  // ====== РЕЙТИНГИ: поиск + быстрые фильтры ======
  const [teamQuery, setTeamQuery] = useState("");
  const [minOver25, setMinOver25] = useState(null); // например 60/70
  const [minOver35, setMinOver35] = useState(null); // 40/50
  const [minCorners, setMinCorners] = useState(null); // 6..10
  const [minCards, setMinCards] = useState(null); // 3..6

  const clearFilters = () => {
    setTeamQuery("");
    setMinOver25(null);
    setMinOver35(null);
    setMinCorners(null);
    setMinCards(null);
  };

  const ratingsData = useMemo(() => {
    const teams = Object.keys(goalsIndex || {});
    const out = [];
    for (const t of teams) {
      out.push({
        team: t,
        g: goalsIndex?.[t] || {},
        c: cornersStats?.[t] || {},
        y: cardsStats?.[t] || {},
        l: lateStats?.[t] || {},
      });
    }
    // по названию
    const q = teamQuery.trim().toLowerCase();
    let arr = q ? out.filter(x => x.team.toLowerCase().includes(q)) : out;

    // быстрые фильтры
    if (minOver25 != null) arr = arr.filter(x => safeNum(x.g.pOver25) >= minOver25);
    if (minOver35 != null) arr = arr.filter(x => safeNum(x.g.pOver35) >= minOver35);
    if (minCorners != null) arr = arr.filter(x => safeNum(x.c.avg) >= minCorners);
    if (minCards != null) arr = arr.filter(x => safeNum(x.y.avg) >= minCards);

    // сортировка по выбранному самому «строгому» фильтру
    if (minOver35 != null) arr = arr.sort((a,b)=>safeNum(b.g.pOver35)-safeNum(a.g.pOver35));
    else if (minOver25 != null) arr = arr.sort((a,b)=>safeNum(b.g.pOver25)-safeNum(a.g.pOver25));
    else if (minCorners != null) arr = arr.sort((a,b)=>safeNum(b.c.avg)-safeNum(a.c.avg));
    else if (minCards != null) arr = arr.sort((a,b)=>safeNum(b.y.avg)-safeNum(a.y.avg));
    else arr = arr.sort((a,b)=> a.team.localeCompare(b.team));

    return arr;
  }, [goalsIndex, cornersStats, cardsStats, lateStats, teamQuery, minOver25, minOver35, minCorners, minCards]);

  // ====== Рендер ======
  if (loading) return <CenterLoading text="Загрузка лиги…" />;

  return (
    <View style={{ flex: 1, backgroundColor: THEME.bg }}>
      {/* header */}
      <View style={{ padding: 16, borderBottomWidth: 1, borderColor: THEME.border }}>
        <Text style={{ color: THEME.text, fontSize: 22, fontWeight: "800" }}>
          {league.name}
        </Text>
        <Text style={{ color: THEME.sub, marginTop: 4 }}>
          {league.country} • Season {season}
        </Text>

        <View style={{ flexDirection: "row", marginTop: 12, flexWrap: "wrap" }}>
          <Tab id="schedule" cur={tab} title="Расписание" onPress={setTab} />
          <Tab id="table" cur={tab} title="Таблица" onPress={setTab} />
          <Tab id="ratings" cur={tab} title="Рейтинги" onPress={setTab} />
          <Tab id="refs" cur={tab} title="Судьи" onPress={setTab} />
        </View>

        {tab === "schedule" && (
          <View style={{ flexDirection: "row", marginTop: 10, flexWrap: "wrap" }}>
            <Chip title="Live" active={flt === "live"} onPress={() => setFlt("live")} />
            <Chip title="Ближайшие" active={flt === "next"} onPress={() => setFlt("next")} />
            <Chip title="Прошедшие" active={flt === "played"} onPress={() => setFlt("played")} />
          </View>
        )}
      </View>

      {/* расписание */}
      {tab === "schedule" && (
        <FlatList
          data={filteredFixtures}
          keyExtractor={(it) => String(it.id)}
          contentContainerStyle={{ padding: 16 }}
          ItemSeparatorComponent={() => <View style={{ height: 8 }} />}
          renderItem={({ item }) => (
            <TouchableOpacity
              onPress={() => openMatch(item)}
              style={{
                backgroundColor: THEME.card,
                borderWidth: 1,
                borderColor: THEME.border,
                borderRadius: 12,
                padding: 12,
              }}
            >
              <View style={{ flexDirection: "row", justifyContent: "space-between" }}>
                <Text style={{ color: THEME.sub, fontSize: 12 }}>{fmtDT(item.date)}</Text>
                {liveCodes.has(item.status) ? (
                  <Text style={{ color: THEME.accent2, fontWeight: "800" }}>
                    LIVE {item.time ? `• ${item.time}'` : ""}
                  </Text>
                ) : (
                  <Text style={{ color: THEME.sub, fontSize: 12 }}>{item.status}</Text>
                )}
              </View>
              <View style={{ height: 6 }} />
              <Text style={{ color: THEME.text, fontWeight: "700" }}>
                {item.home} {item.gH ?? "-"} : {item.gA ?? "-"} {item.away}
              </Text>
              {item.referee ? (
                <Text style={{ color: THEME.sub, fontSize: 12, marginTop: 4 }}>
                  Ref: {item.referee}
                </Text>
              ) : null}
            </TouchableOpacity>
          )}
          ListEmptyComponent={<Text style={{ color: THEME.sub, padding: 16 }}>Нет матчей…</Text>}
        />
      )}

      {/* таблица */}
      {tab === "table" && (
        <ScrollView style={{ flex: 1 }}>
          <View style={{ padding: 16 }}>
            {standings.length === 0 ? (
              <Text style={{ color: THEME.sub }}>Таблица недоступна для этой лиги.</Text>
            ) : (
              standings.map((r) => (
                <Card key={r.teamId}>
                  <View style={{ flexDirection: "row", justifyContent: "space-between" }}>
                    <Text style={{ color: THEME.text, fontWeight: "800" }}>
                      {r.rank}. {r.team}
                    </Text>
                    <Text style={{ color: THEME.text, fontWeight: "800" }}>{r.pts} pts</Text>
                  </View>
                  <Text style={{ color: THEME.sub, marginTop: 6 }}>
                    P:{r.played} • W:{r.win} D:{r.draw} L:{r.lose} • GF:{r.gf} GA:{r.ga} • GD:{r.gd}
                  </Text>
                  {r.form ? <Text style={{ color: THEME.sub, marginTop: 4 }}>Form: {r.form}</Text> : null}
                </Card>
              ))
            )}
          </View>
        </ScrollView>
      )}

      {/* рейтинги + ПОИСК и БЫСТРЫЕ ФИЛЬТРЫ */}
      {tab === "ratings" && (
        <View style={{ flex: 1 }}>
          {/* поиск по командам */}
          <View style={{ padding: 16, borderBottomWidth: 1, borderColor: THEME.border }}>
            <TextInput
              value={teamQuery}
              onChangeText={setTeamQuery}
              placeholder="Поиск команды…"
              placeholderTextColor={THEME.sub}
              style={{
                backgroundColor: THEME.card,
                color: THEME.text,
                padding: 12,
                borderRadius: 12,
                borderWidth: 1,
                borderColor: THEME.border,
              }}
              returnKeyType="search"
            />
            {/* быстрые фильтры */}
            <View style={{ marginTop: 10 }}>
              <Text style={{ color: THEME.sub, marginBottom: 6, fontWeight: "800" }}>
                Быстрые фильтры:
              </Text>
              <View style={{ flexDirection: "row", flexWrap: "wrap" }}>
                {/* Goals */}
                <Chip title="O2.5≥60" active={minOver25===60} onPress={()=>setMinOver25(minOver25===60?null:60)} />
                <Chip title="O2.5≥70" active={minOver25===70} onPress={()=>setMinOver25(minOver25===70?null:70)} />
                <Chip title="O3.5≥40" active={minOver35===40} onPress={()=>setMinOver35(minOver35===40?null:40)} />
                <Chip title="O3.5≥50" active={minOver35===50} onPress={()=>setMinOver35(minOver35===50?null:50)} />
                {/* Corners */}
                <Chip title="Corners≥6" active={minCorners===6} onPress={()=>setMinCorners(minCorners===6?null:6)} />
                <Chip title="≥7" active={minCorners===7} onPress={()=>setMinCorners(minCorners===7?null:7)} />
                <Chip title="≥8" active={minCorners===8} onPress={()=>setMinCorners(minCorners===8?null:8)} />
                <Chip title="≥9" active={minCorners===9} onPress={()=>setMinCorners(minCorners===9?null:9)} />
                <Chip title="≥10" active={minCorners===10} onPress={()=>setMinCorners(minCorners===10?null:10)} />
                {/* Cards */}
                <Chip title="Cards≥3" active={minCards===3} onPress={()=>setMinCards(minCards===3?null:3)} />
                <Chip title="≥4" active={minCards===4} onPress={()=>setMinCards(minCards===4?null:4)} />
                <Chip title="≥5" active={minCards===5} onPress={()=>setMinCards(minCards===5?null:5)} />
                <Chip title="≥6" active={minCards===6} onPress={()=>setMinCards(minCards===6?null:6)} />
                {/* Reset */}
                <Chip title="Сброс" active={false} onPress={clearFilters} />
              </View>
            </View>
          </View>

          {/* список рейтингов с учётом фильтров */}
          <FlatList
            data={ratingsData}
            keyExtractor={(it) => it.team}
            contentContainerStyle={{ padding: 16 }}
            ItemSeparatorComponent={() => <View style={{ height: 8 }} />}
            renderItem={({ item }) => (
              <Card>
                <Text style={{ color: THEME.text, fontWeight: "800" }}>{item.team}</Text>
                <Text style={{ color: THEME.sub, marginTop: 6 }}>
                  Голы: Over2.5 {item.g.pOver25 ?? 0}% • Over3.5 {item.g.pOver35 ?? 0}% (матчей: {item.g.played ?? "—"})
                </Text>
                <Text style={{ color: THEME.sub }}>
                  Угловые: avg {item.c.avg ?? "—"} • O10.5 {item.c.over10_5 ?? 0} / U {item.c.under10_5 ?? 0} (матчей: {item.c.played ?? "—"})
                </Text>
                <Text style={{ color: THEME.sub }}>
                  Карточки: avg {item.y.avg ?? "—"} • O5.5 {item.y.over5_5 ?? 0} / U {item.y.under5_5 ?? 0} (матчей: {item.y.played ?? "—"})
                </Text>
                <Text style={{ color: THEME.sub }}>
                  Поздний гол (≥75’): {item.l.pScoreLate ?? 0}% (матчей: {item.l.played ?? "—"})
                </Text>
              </Card>
            )}
            ListEmptyComponent={<Text style={{ color: THEME.sub, padding: 16 }}>Ничего не найдено под фильтры…</Text>}
          />
        </View>
      )}

      {/* судьи */}
      {tab === "refs" && (
        <FlatList
          data={Object.keys(refStats || {}).sort()}
          keyExtractor={(k) => k}
          contentContainerStyle={{ padding: 16 }}
          ItemSeparatorComponent={() => <View style={{ height: 8 }} />}
          renderItem={({ item: ref }) => {
            const r = refStats?.[ref];
            return (
              <Card>
                <Text style={{ color: THEME.text, fontWeight: "800" }}>{ref}</Text>
                <Text style={{ color: THEME.sub, marginTop: 6 }}>
                  Жёлтые/матч: {r?.avgYellows ?? "—"} • Фолы/матч: {r?.avgFouls ?? "—"}
                </Text>
                <Text style={{ color: THEME.sub }}>
                  Over 5.5 по ЖК: {r?.pOver ?? 0}% • Матчей: {r?.played ?? 0}
                </Text>
              </Card>
            );
          }}
          ListEmptyComponent={
            <Text style={{ color: THEME.sub, padding: 16 }}>Нет данных по судьям…</Text>
          }
        />
      )}
    </View>
  );
}
